# Скопируйте в .env и поправьте под себя:  cp .env.example .env
# docker compose автоматически подхватит .env.

# --- collector ---
SERVICES=all
COLLECT_INTERVAL=43200        # период сбора, сек (12ч)
WEB_PORT=8080                 # порт раздачи списков по HTTP

# --- генерация конфига BGP-фида (нужно для сервиса bird) ---
FEED_ENABLED=1                # 1 — collector после сбора генерирует bgpcollect_routes.conf в ./feed
FEED_ASN=65000                # ваш local ASN
FEED_NEXT_HOP=192.0.2.1       # для совместимости; в blackhole-режиме не используется
FEED_COMMUNITY=65432:500      # community-тег маршрутов (как у antifilter)

# --- bird (профиль bgp / bgp-demo) ---
ROUTER_ID=172.31.0.10
BIRD_RELOAD_INTERVAL=30       # период проверки обновления маршрутов, сек
BGP_PORT=179                  # хостовый порт для входящих BGP-сессий подписчиков

# Демо-пир (профиль bgp-demo). Для продакшна закомментируйте PEER_IP и опишите
# подписчиков в docker/bird/peers.conf.
PEER_IP=172.31.0.20
PEER_ASN=64512
